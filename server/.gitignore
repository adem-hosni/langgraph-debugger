# Server .gitignore (Python)

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Distribution / packaging
build/
dist/
*.egg-info/

# Installer logs
pip-log.txt

# Test / coverage
.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/

# Mypy / pyright
.mypy_cache/
.pyright/

# IDEs
.vscode/
.idea/

# Env files
.env
.env.*

# OS
.DS_Store
Thumbs.db

# SQLite DBs
*.sqlite3
